            }
        ],
        "controls": [
            { "text@theitem_hud.content_tw": {} },
            { "bg@theitem_hud.bg_tw": {} }
        ]
    },

    "panel_tw_tr": {
        "type": "panel",
        "anchor_from": "top_right",
        "anchor_to": "top_right",
        "offset": [-6, 6],
        "size": [160, 11],
        "visible": false,
        "bindings": [
            {
                "binding_type": "global",
                "binding_name": "#hud_title_text_string",
                "binding_name_override": "#tw_t"
            },
            {
                "binding_type": "view",
                "source_property_name": "('%.6s' * #tw_t = '_tw:tr')",
