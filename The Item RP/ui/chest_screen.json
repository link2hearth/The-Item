    "small_chest_screen": {
        "$fart": "$container_title",
        "$new_container_title|default": "$container_title",
        "$container_size|default": 27,
        "modifications": [
            {
                "array_name": "variables",
                "operation": "insert_back",
                "value": [
                    {
                        "requires": "((not (($fart - 'Corpse') = $fart)) and $desktop_screen)",
                        "$screen_content": "chest.54_screen_content",
                        "$screen_bg_content": "common.screen_background",
                        "$container_size": 54
                    },
                    {
                        "requires": "((not (($fart - 'Corpse') = $fart)) and $pocket_screen)",
                        "$container_title": "$new_container_title",
                        "$screen_content": "pocket_containers.panel",
                        "$container_size": 54
                    },
                    {
                        "requires": "(($fart = '\u00A71') and $desktop_screen)",
                        "$new_container_title": "fabmod.backpack.t1",
                        "$screen_content": "chest.t1_screen_content",
                        "$screen_bg_content": "common.screen_background",
                        "$container_size": 99
                    },
                    {
