{
    // The Item - HUD modifications
    // Masque le titre et sous-titre vanilla pour nos marqueurs (_ti: corpse, _tw: waila)

    "hud_title_text": {
        "modifications": [
            {
                "array_name": "bindings",
                "operation": "insert_front",
                "value": [
                    {
                        "binding_type": "global",
                        "binding_name": "#hud_title_text_string",
                        "binding_name_override": "#text"
                    }
                ]
            },
            {
                "array_name": "bindings",
                "operation": "insert_back",
                "value": [
                    {
                        "binding_type": "view",
                        "source_property_name": "(not ('%.2s' * #text = '_t'))",
                        "target_property_name": "#visible"
                    }
                ]
            }
        ]
    },

    // Masque le sous-titre vanilla quand notre indicateur est actif
    // Le sous-titre commence par §r§r§r (corpse) ou §r§r§0 (waila) — détectable via #text
    "hud_subtitle_text": {
        "modifications": [
            {
                "array_name": "bindings",
                "operation": "insert_back",
                "value": [
                    {
                        "binding_type": "view",
                        "source_property_name": "(not ('%.6s' * #text = '§r§r§r')) and (not ('%.6s' * #text = '§r§r§0'))",
                        "target_property_name": "#visible"
                    }
                ]
            }
        ]
    },

    "root_panel": {
        "size": ["100%", "100%"],

        "modifications": [
            {
                "array_name": "controls",
                "operation": "insert_back",
                "value": [
                    { "ti_indicator@theitem_hud.indicator": {} }
                ]
            }
        ]
    }
}
